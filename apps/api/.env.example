# Database
DATABASE_URL="postgresql://nova:GANTI_PASSWORD@postgres:5432/nova"

# JWT — generate: openssl rand -hex 32
JWT_SECRET="isi-random-string-minimal-32-karakter"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Admin JWT (harus berbeda dari JWT_SECRET)
ADMIN_JWT_SECRET="isi-string-berbeda-dari-jwt-secret"

# Redis
REDIS_HOST="redis"
REDIS_PORT="6379"

# Proxmox
PROXMOX_HOST="10.10.10.250"
PROXMOX_PORT="8006"
PROXMOX_TOKEN_ID="nova@pve!nova-token"
PROXMOX_TOKEN_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
PROXMOX_NODE="pve"
PROXMOX_VERIFY_SSL="false"

# SSH ke Proxmox host (untuk terminal VM via qm terminal)
PROXMOX_SSH_USER="root"
PROXMOX_SSH_PASSWORD="password-root-proxmox"
# Alternatif pakai key: PROXMOX_SSH_KEY="/path/to/id_rsa"

# MikroTik (untuk NAT VM — skip jika tidak pakai NAT)
MIKROTIK_HOST="10.10.10.1"
MIKROTIK_USER="nova-api"
MIKROTIK_PASS="password-mikrotik"

# VM NAT
NAT_BRIDGE="vmbr1"
NAT_GATEWAY="10.20.0.1"
NAT_PUBLIC_IP="IP_PUBLIK_SERVER"

# VM Public IP
PUBLIC_BRIDGE="vmbr0"

# Payment — Midtrans
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxx"
MIDTRANS_IS_PRODUCTION="false"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@domain.com"
SMTP_PASS="app-password-gmail"
EMAIL_FROM="NOVA <noreply@domain.com>"

# App
PORT=3000
NODE_ENV="production"
FRONTEND_URL="https://app.domain.com"
ADMIN_URL="https://admin.domain.com"
